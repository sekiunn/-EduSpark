# Docker Compose basic settings
POSTGRES_DB=eduspark
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5432

REDIS_PASSWORD=
REDIS_PORT=6379

OLLAMA_PORT=11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

BACKEND_PORT=8080
CLIENT_PORT=5173
ADMIN_PORT=5174
CLIENT_API_BASE_URL=/api
ADMIN_API_BASE_URL=/api
JAVA_OPTS=-Xms512m -Xmx2048m

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
JWT_SECRET=please-change-this-to-a-long-random-secret

# Runtime feature switches
PPT_THUMBNAIL_ENABLED=true
INTERACTIVE_TEMPLATE_ENABLED=false

# External LLM / embedding services. Fill before using AI generation in production.
RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_EMBEDDING_API_KEY=
LESSON_PLAN_WRITER_EXTERNAL_BASE_URL=https://api.deepseek.com/v1
LESSON_PLAN_WRITER_EXTERNAL_API_KEY=
LESSON_PLAN_WRITER_EXTERNAL_MODEL=deepseek-v4-flash
INTERACTIVE_WRITER_EXTERNAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTERACTIVE_WRITER_EXTERNAL_API_KEY=
INTERACTIVE_WRITER_EXTERNAL_MODEL=qwen3.6-plus

# Aliyun OSS / ASR. Use your own credentials; do not commit real secrets.
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_BASE_URL=
ALIYUN_ASR_ENABLED=false
ALIYUN_ASR_APP_KEY=
ALIYUN_ASR_ACCESS_KEY_ID=
ALIYUN_ASR_ACCESS_KEY_SECRET=
ALIYUN_ASR_TOKEN=
